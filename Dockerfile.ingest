FROM python:3.13-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    "dlt[filesystem]" \
    "dlt[gs]" \
    "dlt[parquet]" \
    gcsfs \
    pyarrow \
    google-cloud-storage \
    python-dotenv \
    requests \
    click

WORKDIR /app

CMD ["python", "--version"]